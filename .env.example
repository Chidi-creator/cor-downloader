# Postgres
DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<db>

# Redis — use REDIS_URL for Upstash/TLS (e.g. rediss://:password@host:6379)
# use REDIS_ADDR for plain local Redis
REDIS_URL=
REDIS_ADDR=<host>:6379
QUEUE_KEY=cor:jobs

# MinIO (or real S3/R2 — change MINIO_ENDPOINT to the real endpoint)
MINIO_ENDPOINT=http://<host>:9000
MINIO_ACCESS_KEY=<access-key>
MINIO_SECRET_KEY=<secret-key>
MINIO_BUCKET=cor-media

# CLI client (point at hosted server when deployed)
COR_API_URL=http://localhost:8080

# HTTP server
HTTP_ADDR=:8080

# Worker pool (tune based on available resources)
WORKER_CONCURRENCY=3
